# vibe-shelf environment variables
#
# Copy this file to .env.local and fill in the values:
#     cp .env.example .env.local
# .env.local holds your real secrets and is gitignored. Never commit it.
# This .env.example file contains no real values and is safe to commit.
#
# For the live site, set the same variables in your Vercel project:
#     Vercel > vibe-shelf > Settings > Environment Variables (Production scope).
# Real secret values belong in .env.local (local) and Vercel (production) only,
# never anywhere in git.

# ---- Required ----

# Discogs personal access token. Reads your collection. Server-side only;
# never sent to the browser.
# Get it from your Discogs account developer settings. Verify the exact path,
# since their menus change; I believe it is https://www.discogs.com/settings/developers
# (generate a personal access token there).
DISCOGS_TOKEN=

# Your Discogs username. Determines whose collection is read.
DISCOGS_USERNAME=

# A descriptive User-Agent string that the Discogs API requires on requests.
# You choose this; include an app name and a contact or URL, for example:
#   vibe-shelf/1.0 (+https://vibe-shelf.vercel.app)
DISCOGS_USER_AGENT=

# Anthropic API key. Required for natural-language / vibe search; without it the
# app falls back to basic keyword search.
# Get it from https://console.anthropic.com/ > API Keys > Create key.
# (The copied search code may also accept the name CLAUDE_API_KEY. Match whichever
# name your lib/search.ts actually reads.)
ANTHROPIC_API_KEY=

# ---- Security (required to access the app) ----

# The password you type to unlock the app (the "owner": full access).
APP_PASSWORD=

# A long random string (>= 16 chars) used to sign login sessions.
# You GENERATE this yourself; it is not fetched from any service. For example:
#   openssl rand -base64 32
# Use a FRESH value; do not reuse another app's session secret.
# If APP_PASSWORD or SESSION_SECRET is missing, the app fails closed (no access).
SESSION_SECRET=

# ---- Optional ----

# A second password for read-only sharing. Guests can browse but cannot change
# anything. Leave blank to disable guest access.
APP_GUEST_PASSWORD=

# Which Claude model to use for query understanding and ranking.
# Defaults to claude-haiku-4-5 (fast, low cost). Verify the current model name in
# the Anthropic docs before overriding, since model names change over time.
ANTHROPIC_MODEL=claude-haiku-4-5

# How long (seconds) to cache the Discogs collection in memory before re-fetching.
# Lower means new records appear faster; higher means fewer Discogs calls.
DISCOGS_CACHE_TTL_SECONDS=300

# ---- Optional: strict global rate limiting (Upstash Redis) ----
# The copied rate limiter is in-memory and best-effort per serverless instance,
# so limits reset on cold starts and are not global. To enforce strict global
# limits, create a free Redis database at https://upstash.com/ and set both below.
# The REST token is a secret.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
